#!/bin/sh

# Verity — PID 1 init
# Brings up networking on the first available link, applies hardening,
# replaces itself with nginx.

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev

mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /tmp
mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /var/log
mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /run
mkdir -p /var/log/nginx /run/nginx

mount -o remount,ro /

# --- Networking ---
# Bring up loopback unconditionally; pick the first non-loopback link with a
# carrier. Falls back to whichever non-loopback link exists if none report
# carrier yet (link state lags driver init on some NICs).

ip link set lo up

IFACE=""
for path in /sys/class/net/*; do
    name=$(basename "$path")
    [ "$name" = "lo" ] && continue
    ip link set "$name" up 2>/dev/null
    if [ "$(cat "$path/carrier" 2>/dev/null)" = "1" ]; then
        IFACE="$name"
        break
    fi
    [ -z "$IFACE" ] && IFACE="$name"
done

if [ -n "$IFACE" ]; then
    echo "verity: requesting DHCP on $IFACE"
    udhcpc -i "$IFACE" -s /usr/share/udhcpc/default.script -b -q 2>/dev/null
fi

# --- Kernel hardening ---
sysctl -p /etc/sysctl.conf >/dev/null 2>&1 || true

echo "verity: starting nginx"
exec nginx -g "daemon off;"
